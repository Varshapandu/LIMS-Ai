APP_NAME=AI LIMS Backend
APP_VERSION=0.1.0
DATABASE_URL=sqlite:///./ai_lims_dev.db
ENVIRONMENT=dev

# IMPORTANT: Generate a strong secret for production. Never use "change-me".
# Example: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_ALGORITHM=HS256

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP (optional for local dev — email features disabled if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=AI LIMS
SMTP_USE_TLS=true
SMTP_USE_SSL=false
